# ─── Supabase PostgreSQL ───────────────────────────────────────────────────────
# App runtime: Transaction pooler (port 6543, pgbouncer=true)
# Migrations/seed: Direct connection (port 5432) via DIRECT_URL
#
# Find both URLs in Supabase → Project Settings → Database → Connection string
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Admin session signing (min 32 characters)
SESSION_SECRET="replace-with-a-long-random-secret-at-least-32-chars"

# Initial admin user (used by `npm run db:seed`)
ADMIN_EMAIL="admin@stampedenergy.com"
ADMIN_PASSWORD="change-me-in-production"
ADMIN_NAME="Stamped Admin"

# ─── Contact form notifications (Resend) ───────────────────────────────────────
# Create an API key at https://resend.com — verify stamped.work domain to send from contact@stamped.work
RESEND_API_KEY="re_xxxxxxxx"
CONTACT_FROM_EMAIL="Stamped Energy <contact@stamped.work>"
# Comma-separated inbox(es) for discovery call alerts (defaults shown if omitted)
CONTACT_NOTIFY_EMAILS="contact@stamped.work,vinayakraizada@gmail.com"

# ─── Split marketing site vs admin CMS ─────────────────────────────────────────
# Production (both domains on the same Next.js deployment):
NEXT_PUBLIC_SITE_URL="https://stamped.work"
ADMIN_APP_ORIGIN="https://admin.stamped.work"
#
# Local development — use localhost and leave admin on the same origin:
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# ADMIN_APP_ORIGIN=""
